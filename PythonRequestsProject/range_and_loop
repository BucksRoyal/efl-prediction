"""
Loop Control Assignment Script
- Checks voting eligibility
- Checks if a number is prime
- Lists numbers 1-100 with prime/non-prime labels
- Demonstrates for loops, while loops, and dictionaries
- Prints "Go To Hell" 5 times
"""

# --- Voting eligibility ---
age = int(input("Enter your age: "))
if age >= 18:
    print("You are eligible to vote.")
else:
    print("You are not eligible to vote.")

print("-" * 20)

# --- Prime check for a number ---
number_to_check = int(input("Enter a number to check if it is prime: "))
is_prime = True
for i in range(2, int(number_to_check**0.5) + 1):
    if number_to_check % i == 0:
        is_prime = False
        break

if is_prime and number_to_check > 1:
    print(f"{number_to_check} is a prime number.")
else:
    print(f"{number_to_check} is not a prime number.")

print("-" * 20)

# --- List numbers 1 to 100 with prime/non-prime ---
print("Numbers 1 to 100 with prime status:")

for num in range(1, 101):
    if num < 2:
        status = "Not a prime number"
    else:
        prime_flag = True
        for i in range(2, int(num**0.5) + 1):
            if num % i == 0:
                prime_flag = False
                break
        status = "Prime number" if prime_flag else "Not a prime number"
    print(f"{num}: {status}")

print("-" * 20)

# --- Print "Go To Hell" 5 times ---
i = 0
while True:
    print("Go To Hell")
    i += 1
    if i == 5:
        break
